<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studentexpensetracker.ui.NavBarController" spacing="2">
    <Button fx:id="navDashboard" text="  Dashboard" styleClass="nav-btn,nav-btn-active"
            onAction="#onDashboard" maxWidth="Infinity"/>
    <Button fx:id="navExpenses" text="  Expenses" styleClass="nav-btn"
            onAction="#onExpenses" maxWidth="Infinity"/>
    <Button fx:id="navSubscriptions" text="  Subscriptions" styleClass="nav-btn"
            onAction="#onSubscriptions" maxWidth="Infinity"/>
    <Button fx:id="navBudgets" text="  Budgets" styleClass="nav-btn"
            onAction="#onBudgets" maxWidth="Infinity"/>
</VBox>
