<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studentexpensetracker.ui.BudgetsController"
      styleClass="content-area" spacing="16">

    <VBox spacing="4">
        <Label text="Budgets" styleClass="page-title"/>
        <Label text="Set monthly limits and track your spending against them" styleClass="page-subtitle"/>
    </VBox>

    <VBox styleClass="card" spacing="14">
        <Label text="Set a Budget" styleClass="section-heading"/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Month" styleClass="filter-label"/>
            <ComboBox fx:id="monthComboBox" prefWidth="140"/>
            <Label text="Category" styleClass="filter-label"/>
            <ComboBox fx:id="categoryComboBox" prefWidth="180"/>
            <Label text="Monthly Limit (£)" styleClass="filter-label"/>
            <TextField fx:id="limitTextField" promptText="e.g. 250.00" prefWidth="140"/>
            <Button text="Save Budget" styleClass="btn-primary" onAction="#onSaveBudget"/>
            <Button text="Refresh" styleClass="btn-secondary" onAction="#onRefresh"/>
        </HBox>
        <Label fx:id="statusLabel" text="" styleClass="status-label"/>
    </VBox>

    <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
        <Label text="Budget Overview" styleClass="section-heading"/>
        <TableView fx:id="budgetsTable" VBox.vgrow="ALWAYS" style="-fx-pref-height: 400;">
            <columns>
                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="220"/>
                <TableColumn fx:id="limitColumn" text="Monthly Limit" prefWidth="150"/>
                <TableColumn fx:id="spentColumn" text="Spent" prefWidth="150"/>
                <TableColumn fx:id="utilisationColumn" text="Utilisation" prefWidth="130"/>
                <TableColumn fx:id="alertColumn" text="Status" prefWidth="130"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
